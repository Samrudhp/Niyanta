# ==========================================
# Niyanta Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values

# ==========================================
# API Keys (REQUIRED)
# ==========================================
GROQ_API_KEY=your_groq_api_key_here

# ==========================================
# Admin Credentials
# ==========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_in_production

# ==========================================
# Database Passwords
# ==========================================
NEO4J_PASSWORD=change_this_password_in_production
RABBITMQ_USER=guest
RABBITMQ_PASS=change_this_password_in_production

# ==========================================
# Service Ports (Optional - defaults shown)
# ==========================================
# Backend API
# BACKEND_PORT=8000

# Frontend
# FRONTEND_PORT=3000

# Redis
# REDIS_PORT=6379

# RabbitMQ
# RABBITMQ_PORT=5672
# RABBITMQ_MANAGEMENT_PORT=15672

# Neo4j
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687

# ChromaDB
# CHROMADB_PORT=8001

# ==========================================
# Performance Tuning (Optional)
# ==========================================
# Number of Uvicorn workers for backend
# WORKERS=2

# Redis memory limit
# REDIS_MAXMEMORY=256mb

# Neo4j memory settings
# NEO4J_HEAP_SIZE=1G
# NEO4J_PAGECACHE_SIZE=512m

# ==========================================
# Development Settings (Optional)
# ==========================================
# LOG_LEVEL=INFO
# DEBUG=false
