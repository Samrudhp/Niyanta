# ==========================================
# Niyanta Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values
# ⚠️  IMPORTANT: .env files are ignored by git. Do NOT commit .env with real credentials!

# ==========================================
# API Keys (REQUIRED)
# ==========================================
# Get your key from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ==========================================
# Admin Credentials (Optional for API endpoints)
# ==========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_in_production

# ==========================================
# Database Passwords (Optional with defaults)
# ==========================================
NEO4J_PASSWORD=niyanta123
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ==========================================
# Service Hosts (For Docker Compose - don't change)
# ==========================================
REDIS_HOST=redis
RABBITMQ_HOST=rabbitmq
NEO4J_HOST=neo4j
CHROMADB_HOST=chromadb

# ==========================================
# Embedding & RAG Configuration (Optional)
# ==========================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
RETRIEVAL_TOP_K=5
MAX_AGENT_STEPS=5
CACHE_TTL_SECONDS=3600

# ==========================================
# Security Notes
# ==========================================
# 1. Change ADMIN_PASSWORD for production
# 2. Change NEO4J_PASSWORD for production  
# 3. Change RABBITMQ_PASSWORD for production
# 4. NEVER commit .env to git
# 5. Keep .env file secure on production servers
